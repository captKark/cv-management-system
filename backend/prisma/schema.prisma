generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Position {
  id         Int    @id @default(autoincrement())
  title      String
  department String
  location   String
  status     String
}

model CV {
  id            Int    @id @default(autoincrement())
  candidateName String
  positionId    Int
  positionTitle String
  status        String
  updatedAt     String
}
model Attribute {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  category   String
  type       String
  createdAt  DateTime @default(now())
}